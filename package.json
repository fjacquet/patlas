{
  "name": "vatlas",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Drop your RVTools export, get a navigable visual atlas of your VMware estate. 100% client-side.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "prebuild": "node scripts/check-supply-chain.mjs",
    "check:supply-chain": "node scripts/check-supply-chain.mjs",
    "check:bundle-size": "node scripts/check-bundle-size.mjs",
    "generate-mib-canary": "node scripts/generate-mib-canary.mjs",
    "generate-inventory-10k": "node scripts/generate-inventory-10k.mjs",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "sync:eos": "node scripts/sync-eos.mjs"
  },
  "dependencies": {
    "@resvg/resvg-wasm": "^2.6.2",
    "@tanstack/react-table": "8.21.3",
    "@tanstack/react-virtual": "3.13.24",
    "echarts": "^6.0.0",
    "echarts-for-react": "^3.0.6",
    "i18next": "^26.2.0",
    "i18next-browser-languagedetector": "^8.2.1",
    "pptxgenjs": "^4.0.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-error-boundary": "^6.1.1",
    "react-i18next": "^17.0.8",
    "sonner": "^2.0.7",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.7.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.6",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.3.0",
    "typescript": "~5.9.3",
    "vite": "^8.0.13",
    "vitest": "^4.1.6"
  }
}
